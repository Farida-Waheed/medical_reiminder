rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /robots/{robotId} {
      allow read: if signedIn() && resource.data.ownerUserId == request.auth.uid;
      allow write: if false;
    }

    match /alerts/{alertId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead'])
        && request.resource.data.isRead == true;
      allow create, delete: if false;
    }
  }
}
