rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function robotDoc(robotId) {
      return get(/databases/$(database)/documents/robots/$(robotId));
    }

    function isCaregiver(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "caregiver";
    }

    function isAssignedCaregiver(caregiverId) {
      return signedIn() && caregiverId == request.auth.uid;
    }

    function isAssignedRobot(robotId) {
      return signedIn()
        && robotDoc(robotId).data.robotAuthUid == request.auth.uid;
    }

    function isCurrentRobotDoc() {
      return signedIn()
        && resource.data.robotAuthUid == request.auth.uid;
    }

    function hasOnlyRobotStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'batteryLevel', 'lastSeen', 'currentTask']);
    }

    function hasOnlyCaregiverAlertUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['isRead', 'isResolved', 'resolvedAt']);
    }

    function validRobotStatusUpdate() {
      return isCurrentRobotDoc()
        && hasOnlyRobotStatusFields()
        && request.resource.data.robotId == resource.data.robotId
        && request.resource.data.caregiverId == resource.data.caregiverId
        && request.resource.data.robotAuthUid == resource.data.robotAuthUid
        && request.resource.data.patientRoom == resource.data.patientRoom
        && request.resource.data.status is string
        && request.resource.data.batteryLevel is int
        && request.resource.data.batteryLevel >= 0
        && request.resource.data.batteryLevel <= 100
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.currentTask is string;
    }

    function validRobotAlertCreate(alertId) {
      let robot = robotDoc(request.resource.data.robotId);
      return signedIn()
        && robot.data.robotAuthUid == request.auth.uid
        && request.resource.data.alertId == alertId
        && request.resource.data.caregiverId == robot.data.caregiverId
        && request.resource.data.patientRoom == robot.data.patientRoom
        && request.resource.data.keys().hasOnly([
          'alertId',
          'title',
          'message',
          'type',
          'severity',
          'robotId',
          'caregiverId',
          'patientRoom',
          'timestamp',
          'isRead',
          'isResolved',
          'resolvedAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.type in [
          'fall_detected',
          'unknown_person_detected',
          'patient_not_detected',
          'robot_disconnected',
          'robot_battery_low',
          'emergency'
        ]
        && request.resource.data.severity in ['info', 'warning', 'emergency']
        && request.resource.data.timestamp is timestamp
        && request.resource.data.isRead == false
        && request.resource.data.isResolved == false
        && request.resource.data.resolvedAt == null;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if isCaregiver(userId)
        && request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'role']);
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'email'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
      allow delete: if false;

    }

    match /robots/{robotId} {
      allow read: if isAssignedCaregiver(resource.data.caregiverId)
        || isCurrentRobotDoc();
      allow update: if validRobotStatusUpdate();
      allow create, delete: if false;
    }

    match /alerts/{alertId} {
      allow read: if isAssignedCaregiver(resource.data.caregiverId)
        || isAssignedRobot(resource.data.robotId);
      allow create: if validRobotAlertCreate(alertId);
      allow update: if isAssignedCaregiver(resource.data.caregiverId)
        && hasOnlyCaregiverAlertUpdateFields();
      allow delete: if false;
    }
  }
}
